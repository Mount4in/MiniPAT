page {
--primary-color:#824c96}

.primary-text {
    color: var(--primary-color);
}

.listEmpty {
    align-items: center;
    display: -webkit-flex;
    display: flex;
    flex-direction: column;
    height: 100%;
    width: 100%;
}

.listEmpty-inner {
    color: #747577;
    font-size: 28rpx;
    margin-top: 20%;
    text-align: center;
}

.listEmpty-inner__icon {
    height: 338rpx;
    width: 500rpx;
}

.loading {
    color: #52585f;
    font-family: PingFangSC,PingFang SC;
    font-size: 28rpx;
    font-weight: 400;
    margin-top: 20rpx;
    text-align: center;
}

