.movable-area {
    box-sizing: border-box;
    height: 100vh;
    left: 0;
    pointer-events: none;
    position: fixed;
    top: 0;
    width: 100vw;
    z-index: 50;
}

.movable-area .movable-view {
    pointer-events: auto;
}

.movable-area .float-box {
    display: inline-block;
    height: 112rpx;
    vertical-align: top;
    width: 112rpx;
}

.is-disabled {
    filter: grayscale(1);
    pointer-events: none;
}

.animate-scale {
    animation: zoomLarge .15s ease-in;
    animation-fill-mode: forwards;
}

@-webkit-keyframes zoomLarge {
0% {
    transform: scale(1);
}

50% {
    transform: scale(.8);
}

to {
    transform: scale(1);
}

}
@keyframes zoomLarge {
0% {
    transform: scale(1);
}

50% {
    transform: scale(.8);
}

to {
    transform: scale(1);
}

}
