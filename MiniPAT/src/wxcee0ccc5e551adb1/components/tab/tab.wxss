.tab {
    align-items: center;
    display: -webkit-flex;
    display: flex;
    overflow: auto;
    width: 100%;
}

.tab-item {
    color: #151719;
    flex: 1;
    padding: 10rpx 20rpx;
    position: relative;
    text-align: center;
}

.tab-item::after {
    background: #824c96;
    border-radius: 4rpx;
    bottom: 0;
    content: "";
    display: block;
    height: 8rpx;
    left: 20%;
    max-height: 0rpx;
    position: absolute;
    transition-duration: .3s;
    transition-timing-function: ease-in-out;
    width: 60%;
}

.tab-item--activity {
    color: #824c96;
}

.tab-item--activity::after {
    max-height: 8rpx;
}

