view {
    box-sizing: border-box;
}

.screenRange {
    color: #171921;
    font-size: 28rpx;
    font-weight: 400;
    height: 100vh;
    padding-left: 30rpx;
    padding-right: 30rpx;
    z-index: 10;
}

.screenRange-hide {
    height: 0;
    overflow: hidden;
}

.screenRange-container {
    background-color: #fff;
    border-radius: 0rpx 0rpx 16rpx 16rpx;
    margin: 0 30rpx;
    padding: 0 0rpx 50rpx 30rpx;
}

.screenRange-list {
    margin-bottom: 40rpx;
    max-height: 48vh;
    overflow-y: scroll;
    padding-right: 30rpx;
}

.title {
    padding: 18rpx 0;
}

.slider {
    margin: 0rpx 30rpx 20rpx;
}

.sliderText {
    color: #824c96!important;
    font-size: 28rpx;
    font-weight: 400;
    margin-bottom: 10rpx;
    text-align: center;
}

.sliderText.minMax {
    text-align: left;
}

.conditionalOptions {
    flex-wrap: wrap;
}

.conditionalOptions,.conditionalOptions view {
    align-items: center;
    display: -webkit-flex;
    display: flex;
}

.conditionalOptions view {
    border: 2rpx solid #f2f3f4;
    border-radius: 8rpx;
    color: #171921;
    font-family: PingFangSC,PingFang SC;
    font-size: 28rpx;
    font-weight: 400;
    height: 60rpx;
    justify-content: center;
    margin-right: 20rpx;
    margin-top: 20rpx;
    width: 196rpx;
}

.conditionalOptions view:nth-child(3n) {
    margin-right: 0rpx;
}

.positionTypeChooseActive,.salaryChooseActive {
    background: rgba(130,76,150,.1);
    color: #824c96!important;
}

.footer {
    margin-right: 30rpx;
}

.footer,.footer view {
    align-items: center;
    display: -webkit-flex;
    display: flex;
}

.footer view {
    background: #fff;
    border: 2rpx solid #824c96;
    border-radius: 36rpx;
    color: #824c96;
    flex: 1;
    font-family: PingFangSC,PingFang SC;
    font-size: 32rpx;
    font-weight: 400;
    height: 72rpx;
    justify-content: center;
    width: 300rpx;
}

.footer .submit {
    background: #824c96;
    border-radius: 36rpx;
    color: #fff;
    margin-left: 30rpx;
}

