view {
    box-sizing: border-box;
}

.biographicalNotesFlagaction-list {
    max-height: calc(100vh - 430rpx);
    overflow-y: scroll;
    padding: 42rpx 30rpx 0;
}

.biographicalNotesFlag {
    color: #824c96;
    font-family: PingFangSC,PingFang SC;
    font-size: 24rpx;
    font-weight: 400;
    line-height: 80rpx;
    text-align: center;
}

.radioActive {
    position: absolute;
    right: -2rpx;
    top: -2rpx;
}

.radioActive image {
    height: 56rpx;
    width: 56rpx;
}

.biographicalNotes {
    height: 100rpx;
    margin-left: 20rpx;
    margin-right: 20rpx;
    width: 100rpx;
}

.title {
    align-items: center;
    color: #151719;
    display: -webkit-flex;
    display: flex;
    font-size: 34rpx;
    font-weight: 500;
    height: 168rpx;
}

.title,.title .cell-time {
    font-family: PingFangSC,PingFang SC;
}

.title .cell-time {
    color: #52585f;
    font-size: 28rpx;
    font-weight: 400;
    margin-top: 32rpx;
}

.van-cell-list {
    border: 2rpx solid transparent!important;
    border-radius: 16rpx!important;
}

.van-active-cell-list,.van-cell-list {
    background: #fff!important;
    box-shadow: 0rpx 8rpx 24rpx 0rpx rgba(0,0,0,.1)!important;
    box-sizing: border-box!important;
    margin-bottom: 20rpx!important;
    padding: 0!important;
    position: relative;
}

.van-active-cell-list {
    border: 2rpx solid #824c96!important;
    border-radius: 16rpx!important;
}

.biographicalNotesBtn {
    background-color: #fff;
    color: #52585f;
    font-family: PingFangSC,PingFang SC;
    font-size: 30rpx;
    font-weight: 400;
    justify-content: space-between;
    margin: 0 50rpx 50rpx;
}

.biographicalNotesBtn,.biographicalNotesBtn view {
    align-items: center;
    display: -webkit-flex;
    display: flex;
}

.biographicalNotesBtn view {
    background-color: #adaeaf;
    border-radius: 20rpx;
    color: #fff;
    flex: 1;
    height: 80rpx;
    justify-content: center;
}

.biographicalNotesBtn .submit {
    background-color: #824c96;
    margin-left: 70rpx;
}

.resumeName {
    line-clamp: 1;
    display: -webkit-box;
    overflow: hidden;
    word-break: break-all;
}

