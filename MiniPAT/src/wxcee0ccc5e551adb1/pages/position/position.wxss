.selectPositionType {
    position: relative;
}

.selectPositionType,.selectPositionType-bg {
    height: 796rpx;
    width: 610rpx;
}

.selectPositionType .selectPositionType-list {
    align-items: center;
    bottom: 0;
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex;
    flex-direction: column;
    left: 0;
    padding-top: 136rpx;
    position: absolute;
    right: 0;
    top: 0;
}

.selectPositionType .selectPositionType-list view {
    align-items: center;
    background: #fff;
    border-radius: 16rpx;
    color: #4d148c;
    display: -webkit-flex;
    display: flex;
    font-family: PingFangSC,PingFang SC;
    font-size: 32rpx;
    font-weight: 500;
    height: 120rpx;
    justify-content: center;
    margin-bottom: 40rpx;
    width: 510rpx;
}

.positionList .positionList-screen-group {
    margin: 20rpx 30rpx;
    overflow-x: scroll;
}

.positionList .positionList-screen-group::-webkit-scrollbar {
    display: none;
}

.positionList .positionList-screen-group .positionList-group {
    align-items: center;
    display: -webkit-flex;
    display: flex;
    padding-right: 60rpx;
    width: -webkit-fit-content;
    width: fit-content;
}

.positionList .positionList-screen-group .positionList-group view {
    align-items: center;
    display: -webkit-flex;
    display: flex;
    height: 180rpx;
    justify-content: center;
    margin-right: 20rpx;
    position: relative;
    width: 300rpx;
}

.positionList .positionList-screen-group .positionList-group view image {
    height: 180rpx;
    width: 300rpx;
}

.positionList .positionList-screen-group .positionList-group view text {
    color: #fff;
    font-family: PingFangSC,PingFang SC;
    font-size: 36rpx;
    font-weight: 400;
    position: absolute;
    text-align: center;
    top: 50%;
    transform: translate(0,-50%);
    width: 87%;
}

.positionList .positionList-company {
    height: 76rpx;
    margin: 28rpx auto 16rpx;
    width: 266rpx;
}

.positionList .positionList-company image {
    height: 76rpx;
    width: 266rpx;
}

.positionList .positionList-screen {
    background: #fff;
    border-radius: 16rpx;
    box-shadow: 0rpx 8rpx 24rpx 0rpx rgba(0,0,0,.1);
    margin: 0rpx 30rpx 0;
    padding-bottom: 20rpx;
    padding-top: 20rpx;
    position: -webkit-sticky;
    position: sticky;
    top: calc(44px + env(safe-area-inset-top));
    width: 690rpx;
    z-index: 2;
}

.positionList .positionList-screen .positionList-screen-search {
    align-items: center;
    background: #f2f3f4;
    border-radius: 40rpx;
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex;
    height: 80rpx;
    margin-bottom: 10rpx;
    margin-left: 30rpx;
    padding: 0 26rpx;
    width: 630rpx;
}

.positionList .positionList-screen .positionList-screen-search .weui-input {
    padding: 0 14rpx;
}

.positionList .positionList-screen .positionList-screen-down {
    align-items: center;
    display: -webkit-flex;
    display: flex;
    justify-content: space-between;
    margin-top: 10rpx;
    padding: 0rpx 30rpx;
    position: relative;
}

.positionList .positionList-screen .positionList-screen-down .fieldValue {
    display: -webkit-flex;
    display: flex;
}

.positionList .positionList-screen .positionList-screen-down .fieldValue .value {
    line-clamp: 1;
    box-sizing: border-box;
    display: -webkit-box;
    max-width: 180rpx;
    overflow: hidden;
    word-break: break-all;
}

.positionList .positionList-screen .positionList-screen-down text {
    color: #151719;
    font-family: PingFangSC,PingFang SC;
    font-size: 28rpx;
    font-weight: 400;
    margin-right: 40rpx;
}

.positionList .officialAccountIsShow {
    padding-bottom: 120rpx;
}

.positionListSearch {
    padding: 7rpx 0;
}

.active {
    color: #824c96!important;
}

.positionList-filter {
    display: -webkit-flex;
    display: flex;
}

.nav-bar {
    position: -webkit-sticky;
    position: sticky;
    top: 0;
}

.position-tab-item {
    font-size: 34rpx;
    font-weight: 500;
}

