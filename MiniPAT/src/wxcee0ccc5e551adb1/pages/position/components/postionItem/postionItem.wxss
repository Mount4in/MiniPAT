.postionItem {
    border-radius: 16rpx;
    box-shadow: 0rpx 8rpx 24rpx 0rpx rgba(0,0,0,.1);
    box-sizing: border-box;
    margin-left: 30rpx;
    margin-top: 20rpx;
    padding: 24rpx 20rpx 20rpx;
    width: 690rpx;
}

.postionItem .postionItem-name {
    line-clamp: 1;
    word-wrap: break-word;
    box-sizing: border-box;
    color: #151719;
    display: -webkit-box;
    flex: 1;
    font-size: 34rpx;
    overflow: hidden;
    word-break: break-all;
}

.postionItem .postionItem-name,.postionItem .postionItem-salary {
    font-family: PingFangSC,PingFang SC;
    font-weight: 500;
    margin-bottom: 20rpx;
}

.postionItem .postionItem-salary {
    color: #824c96;
    font-size: 32rpx;
}

.postionItem .postionItem-salary text {
    font-size: 20rpx;
}

.flex-btw,.postionItem .postionItem-describe {
    display: -webkit-flex;
    display: flex;
    justify-content: space-between;
}

.postionItem .postionItem-describe {
    align-items: center;
}

.postionItem-welfare,.postionItem-welfare-label {
    align-items: center;
    display: -webkit-flex;
    display: flex;
}

.postionItem-welfare-label {
    background: #f7f8fa;
    border-radius: 4rpx;
    color: #52585f;
    font-size: 28rpx;
    margin-bottom: 8rpx;
    margin-right: 8rpx;
    padding: 2rpx 12rpx;
}

.postionItem-describe-address {
    align-items: center;
    display: -webkit-flex;
    display: flex;
}

.address {
    line-clamp: 1;
    word-wrap: break-word;
    box-sizing: border-box;
    color: #151719;
    display: -webkit-box;
    font-size: 28rpx;
    max-width: 400rpx;
    overflow: hidden;
    word-break: break-all;
}

.address text {
    display: inline-block;
}

.postionItem .postionItem-describe-deliver {
    align-items: center;
    background: #824c96;
    border: 2rpx solid #824c96;
    border-radius: 8rpx;
    color: #fff;
    display: -webkit-flex;
    display: flex;
    font-size: 32rpx;
    font-weight: 400;
    font-weight: 500;
    height: 56rpx;
    justify-content: center;
    width: 150rpx;
}

.postionItem .postionItem-describe-deliver.already {
    background: #f2f3f4;
    border: none;
    color: #cccfd5;
}

.postionItem .postionItem-describe-deliver .postionItem-describe-deliver-icon {
    height: 30rpx;
    width: 28rpx;
}

.postionItem-hot {
    align-items: center;
    background: #ffe6e6;
    border-radius: 4rpx;
    display: -webkit-flex;
    display: flex;
    height: 40rpx;
    justify-content: center;
    padding: 4rpx 10rpx;
}

.postionItem-hot-text {
    color: #ff4d4f;
    font-size: 20rpx;
    margin-left: 4rpx;
}

.postionItem-hot-icon {
    height: 28rpx;
    width: 24rpx;
}

.icon-location-nav {
    height: 22rpx;
    margin-right: 8rpx;
    width: 16rpx;
}

.distance {
    color: #151719;
    font-size: 28rpx;
}

