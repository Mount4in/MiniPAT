.privacyPolicy {
    background: #fff;
    border-radius: 16rpx;
    box-shadow: 0rpx 8rpx 24rpx 0rpx rgba(0,0,0,.1);
    margin: 40rpx 30rpx;
    width: 690rpx;
}

.privacyPolicy .item {
    align-items: center;
    border-bottom: 2rpx solid #e2e6e8;
    box-sizing: border-box;
    color: #151719;
    display: -webkit-flex;
    display: flex;
    font-family: PingFangSC,PingFang SC;
    font-size: 28rpx;
    font-weight: 400;
    height: 100rpx;
    justify-content: space-between;
    margin: 0 30rpx;
}

.privacyPolicy .item .myArrow {
    height: 36rpx;
    width: 36rpx;
}

.privacyPolicy .item.-b {
    border-bottom: none;
}

