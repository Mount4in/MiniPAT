view {
    box-sizing: border-box;
}

.position-filter {
    color: #171921;
    display: -webkit-flex;
    display: flex;
    flex-direction: column;
    font-size: 28rpx;
    font-weight: 400;
    height: 100vh;
    padding: 20rpx 30rpx 80rpx;
}

.position-filter-list {
    flex: 1;
    margin-bottom: 40rpx;
    overflow: auto;
}

.title {
    padding: 18rpx 0;
}

.slider {
    margin: 0rpx 30rpx 20rpx;
}

.sliderText {
    color: #824c96!important;
    font-size: 28rpx;
    font-weight: 400;
    margin-bottom: 10rpx;
    text-align: center;
}

.sliderText.minMax {
    text-align: left;
}

.conditionalOptions {
    flex-wrap: wrap;
}

.conditionalOptions,.conditionalOptions view {
    align-items: center;
    display: -webkit-flex;
    display: flex;
}

.conditionalOptions view {
    border: 2rpx solid #f2f3f4;
    border-radius: 8rpx;
    color: #171921;
    font-family: PingFangSC,PingFang SC;
    font-size: 28rpx;
    font-weight: 400;
    height: 60rpx;
    justify-content: center;
    margin-right: 50rpx;
    margin-top: 20rpx;
    width: 196rpx;
}

.conditionalOptions view:nth-child(3n) {
    margin-right: 0rpx;
}

.positionTypeChooseActive,.salaryChooseActive {
    background: rgba(130,76,150,.1);
    color: #824c96!important;
}

.footer {
    margin: 0 30rpx;
}

.footer,.footer view {
    align-items: center;
    display: -webkit-flex;
    display: flex;
}

.footer view {
    background: #fff;
    border: 2rpx solid #824c96;
    border-radius: 36rpx;
    color: #824c96;
    flex: 1;
    font-family: PingFangSC,PingFang SC;
    font-size: 32rpx;
    font-weight: 400;
    height: 72rpx;
    justify-content: center;
    width: 300rpx;
}

.footer .submit {
    background: #824c96;
    border-radius: 36rpx;
    color: #fff;
    margin-left: 30rpx;
}

.van-slider__button {
    border: 2rpx solid #824c96!important;
    height: 40rpx!important;
    width: 40rpx!important;
}

