.container {
    align-items: center;
    display: -webkit-flex;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.container .container_header {
    padding-top: 150rpx;
    text-align: center;
}

.container .container_header .container_header_logo {
    height: 144rpx;
    width: 144rpx;
}

.container .container_header .container_header_title {
    color: 333;
    font-family: PingFangSC-Semibold,PingFangSC;
    font-size: 32rpx;
    font-weight: 600;
    line-height: 48rpx;
    margin-top: 14rpx;
    text-align: center;
}

.container_content {
    margin-top: 160rpx;
    padding: 0rpx 17rpx;
}

.container_content button {
    background-color: #824c96;
    border: none;
    border-radius: 30rpx;
    color: #fff;
    font-size: 30rpx;
    font-weight: 400;
    outline: none;
    width: 600rpx;
}

.container_content_mobile {
    color: #64718a;
    font-size: 28rpx;
    line-height: 60rpx;
    margin-left: 78rpx;
    margin-right: 78rpx;
    margin-top: 12rpx;
    padding: 16rpx 0;
}

.container_bottom,.container_content_mobile {
    font-family: PingFangSC-Regular,PingFangSC;
    font-weight: 400;
    text-align: center;
}

.container_bottom {
    align-items: center;
    bottom: 80rpx;
    color: #969697;
    display: -webkit-flex;
    display: flex;
    font-size: 25rpx;
    justify-content: center;
    position: fixed;
    width: 100%;
}

.container_bottom_text {
    color: #824c96;
}

.privacyPolicyTitle {
    border: 2rpx solid #ebe5e5;
    font-size: 32rpx;
    font-weight: 700;
    padding: 20rpx 0;
    text-align: center;
}

.privacyPolicyText {
    max-height: calc(100vh - 600rpx);
    overflow-y: scroll;
    padding: 20rpx;
}

.privacyPolicyText view {
    font-size: 26rpx;
    line-height: 60rpx;
}

.privacyPolicyText view text {
    color: #824c96;
}

.privacyPolicyFooter {
    padding: 0rpx 0 20rpx;
    text-align: center;
}

.privacyPolicyFooter .privacyPolicyFooterTips {
    color: #867e7e;
    font-size: 24rpx;
    padding: 0 20rpx;
}

.privacyPolicyFooter .privacyPolicyBtn {
    margin-top: 30rpx;
}

.privacyPolicyFooter .privacyPolicyBtn,.privacyPolicyFooter .privacyPolicyBtn button,.privacyPolicyFooter .privacyPolicyBtn view {
    align-items: center;
    display: -webkit-flex;
    display: flex;
    justify-content: center;
}

.privacyPolicyFooter .privacyPolicyBtn button,.privacyPolicyFooter .privacyPolicyBtn view {
    background: #824c96;
    border-radius: 40rpx;
    box-sizing: border-box;
    color: #fff;
    height: 80rpx;
    margin: 0;
    width: 300rpx;
}

.privacyPolicyFooter .privacyPolicyBtn .noAgree {
    background: #fff;
    border: 2rpx solid #824c96;
    color: #824c96;
    margin-right: 30rpx;
}

