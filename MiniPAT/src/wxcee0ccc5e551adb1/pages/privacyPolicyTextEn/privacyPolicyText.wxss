.privacyPolicyText {
    box-sizing: border-box;
    color: #151719;
    font-family: PingFangSC,PingFang SC;
    font-size: 28rpx;
    font-weight: 400;
    line-height: 50rpx;
    padding: 40rpx 30rpx 200rpx;
}

.privacyPolicyText > view {
    background: #fff;
    border-radius: 16rpx;
    box-shadow: 0rpx 8rpx 24rpx 0rpx rgba(0,0,0,.1);
    padding: 40rpx 30rpx;
}

.privacyPolicyText .title {
    font-size: 36rpx;
    font-weight: bolder;
    margin-bottom: 40rpx;
    text-align: center;
}

.privacyPolicyText .subtitle {
    font-size: 28rpx;
    font-weight: 700;
    margin: 20rpx 0;
}

.privacyPolicyText text {
    color: #824c96;
    text-decoration: underline;
}

.table {
    background: #fff;
    border: 1rpx solid #dad9d9;
    border-bottom: 0;
    display: -webkit-flex;
    display: flex;
    font-size: 25rpx;
}

.left_col_item:nth-child(1),.tr_th.tr_td {
    font-weight: 700;
}

.table_left_column {
    flex-direction: column;
    height: auto;
}

.left_col_item,.table_left_column {
    display: -webkit-flex;
    display: flex;
    justify-content: center;
    width: 220rpx;
}

.left_col_item {
    word-wrap: break-word;
    align-items: center;
    border-bottom: 1rpx solid #e5e5e5;
    color: #000;
    min-height: 90rpx;
    white-space: pre-line;
    word-break: break-all;
}

.table_right_scroll_box {
    border-left: 1rpx solid #e5e5e5;
    font-weight: 400;
    height: auto;
    overflow-x: scroll;
    white-space: nowrap;
    width: 1000rpx;
}

.box2 .table_tr_item,.table_right_scroll_box.box2 {
    width: 800rpx;
}

.table_tr_item {
    display: -webkit-flex;
    display: flex;
    flex-direction: row;
    width: 1800rpx;
}

.tr_td {
    border: 1rpx solid #dad9d9;
    border-left: 0;
    border-top: 0;
    flex-direction: column;
    justify-content: center;
    min-height: 90rpx;
    width: 470rpx;
}

.tr_td,.tr_td_row {
    word-wrap: break-word;
    display: -webkit-flex;
    display: flex;
    white-space: pre-line;
    word-break: break-all;
}

.tr_td_row {
    align-items: center;
    border-bottom: 1rpx solid #e5e5e5;
    flex-basis: auto;
    flex-grow: 1;
    min-height: 60rpx;
    width: 100%;
}

.tr_td_row:last-child {
    border-bottom: none;
}

.link {
    color: #824c96;
    text-decoration: underline;
}

.privacyPolicyText-btn {
    background-color: #fff;
    bottom: 0;
    box-shadow: inset 0rpx 1rpx 2rpx 0rpx rgba(0,0,0,.1);
    left: 0;
    padding: 16rpx 0 60rpx;
    position: fixed;
    right: 0;
}

.privacyPolicyText-btn,.privacyPolicyText-btn view {
    align-items: center;
    display: -webkit-flex;
    display: flex;
    justify-content: center;
}

.privacyPolicyText-btn view {
    background: #fff;
    border: 2rpx solid #824c96;
    border-radius: 40rpx;
    color: #824c96;
    font-family: PingFangSC,PingFang SC;
    font-size: 32rpx;
    font-weight: 400;
    height: 80rpx;
    width: 690rpx;
}

