.myDelivery-postionItem {
    background: #fff;
    border-radius: 16rpx;
    box-shadow: 0rpx 8rpx 24rpx 0rpx rgba(0,0,0,.1);
    box-sizing: border-box;
    margin-bottom: 20rpx;
    padding: 24rpx 20rpx 20rpx;
    width: 690rpx;
}

.myDelivery-postionItem .myDelivery-postionItem-name {
    align-items: center;
    box-sizing: border-box;
    color: #151719;
    display: -webkit-flex;
    display: flex;
    font-family: PingFangSC,PingFang SC;
    font-size: 34rpx;
    font-weight: 500;
    justify-content: space-between;
    margin-bottom: 20rpx;
}

.myDelivery-postionItem .myDelivery-postionItem-name .name {
    line-clamp: 1;
    display: -webkit-box;
    flex: 1;
    overflow: hidden;
    word-break: break-all;
}

.myDelivery-postionItem .myDelivery-postionItem-name .status {
    background: #fbf0ff;
    border-radius: 4rpx;
    color: #824c96;
    font-family: PingFangSC,PingFang SC;
    font-size: 24rpx;
    font-weight: 600;
    padding: 6rpx 12rpx;
}

.myDelivery-postionItem .myDelivery-postionItem-name .status.is-3 {
    background: #fff0eb;
    color: #fe8201;
}

.myDelivery-postionItem .myDelivery-postionItem-name .status.is-4,.myDelivery-postionItem .myDelivery-postionItem-name .status.is-5 {
    background: #effff3;
    color: #1acb42;
}

.myDelivery-postionItem .myDelivery-postionItem-salary {
    color: #824c96;
    font-family: PingFangSC,PingFang SC;
    font-size: 32rpx;
    font-weight: 500;
    margin-bottom: 20rpx;
}

.myDelivery-postionItem .myDelivery-postionItem-salary text {
    font-size: 20rpx;
}

.myDelivery-postionItem .myDelivery-postionItem-describe {
    align-items: center;
    display: -webkit-flex;
    display: flex;
    justify-content: space-between;
}

.myDelivery-postionItem .myDelivery-postionItem-describe .myDelivery-postionItem-describe-lable {
    align-items: center;
    color: #52585f;
    display: -webkit-flex;
    display: flex;
    flex: 1;
    flex-wrap: wrap;
    font-family: PingFangSC,PingFang SC;
    font-size: 28rpx;
    font-weight: 400;
    margin-right: 20rpx;
}

.myDelivery-postionItem .myDelivery-postionItem-describe .myDelivery-postionItem-describe-lable view {
    background: #f7f8fa;
    border-radius: 4rpx;
    margin-bottom: 8rpx;
    margin-right: 8rpx;
    padding: 2rpx 12rpx;
}

.myDelivery-postionItem .myDelivery-postionItem-describe-deliver {
    color: #52585f;
    font-family: PingFangSC,PingFang SC;
    font-size: 28rpx;
    font-weight: 400;
}

.myDelivery-postionItem .myDelivery-postionItem-describe-deliver .myDelivery-postionItem-describe-deliver-icon {
    height: 30rpx;
    width: 28rpx;
}

.address {
    line-clamp: 1;
    word-wrap: break-word;
    box-sizing: border-box;
    display: -webkit-box;
    max-width: 300rpx;
    overflow: hidden;
    word-break: break-all;
}

