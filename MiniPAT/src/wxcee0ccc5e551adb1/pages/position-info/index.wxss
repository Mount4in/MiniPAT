.popup,.popup-title {
    text-align: center;
}

.popup-title {
    color: #303133;
    font-family: PingFangSC,PingFang SC;
    font-size: 34rpx;
    font-weight: 500;
    line-height: 48rpx;
    margin-bottom: 32rpx;
    padding: 32rpx 0;
}

.popup-close {
    margin: -20rpx;
    padding: 20rpx;
    position: absolute;
    right: 50rpx;
    top: 38rpx;
}

.popup-hd {
    position: relative;
}

.popup-bd {
    align-items: center;
    display: -webkit-flex;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.popup-block {
    height: 688rpx;
    position: relative;
    width: 450rpx;
}

.popup-block__background {
    height: 688rpx;
    left: 0;
    position: absolute;
    top: 0;
    width: 450rpx;
}

.popup .position-info {
    background: #fff;
    border-radius: 16rpx;
    height: 492rpx;
    left: 40rpx;
    position: absolute;
    top: 156rpx;
    width: 370rpx;
    z-index: 2;
}

.popup .position-info .share-decoration1,.popup .position-info .share-decoration2 {
    height: 32rpx;
    position: absolute;
    width: 36rpx;
    z-index: 2;
}

.popup .position-info .share-decoration1 {
    left: 16rpx;
    top: 16rpx;
}

.popup .position-info .share-decoration2 {
    bottom: 16rpx;
    right: 16rpx;
}

.popup .position-title {
    font-weight: 400;
    margin-bottom: 32rpx;
    margin-top: 20rpx;
}

.popup .position-desc,.popup .position-title {
    color: #303133;
    font-size: 24rpx;
    line-height: 34rpx;
}

.popup .position-desc {
    font-weight: 500;
    margin-bottom: 16rpx;
}

.popup .position-salary {
    color: #824c96;
    font-size: 28rpx;
    font-weight: 600;
}

.popup .position-salary .position-salary-value {
    align-items: center;
    display: -webkit-flex;
    display: flex;
}

.popup .position-salaryLabel {
    color: #824c96;
    font-size: 20rpx;
    font-weight: 600;
}

.popup .position-qrcode {
    height: 160rpx;
    margin-bottom: 32rpx;
    margin-top: 60rpx;
    vertical-align: top;
    width: 160rpx;
}

.popup .position-more {
    color: #52585f;
    font-size: 20rpx;
    font-weight: 400;
    line-height: 28rpx;
}

.popupHandle {
    display: -webkit-flex;
    display: flex;
    justify-content: space-between;
    padding-bottom: 8rpx;
    padding-top: 50rpx;
    width: 450rpx;
}

.popupHandle .popupHandle-item-button {
    margin: 0;
    width: auto;
}

.popupHandle-item {
    background-color: initial;
    color: #52585f;
    font-size: 24rpx;
    font-weight: 400;
    line-height: 34rpx;
    padding: 0;
    width: 172rpx;
}

.popupHandle-item__icon {
    height: 76rpx;
    margin-bottom: 16rpx;
    width: 76rpx;
}

.popup-share-bg {
    height: 688rpx;
    width: 450rpx;
}

page {
    background: #fff;
}

.page {
    display: -webkit-flex;
    display: flex;
    flex-direction: column;
    height: 100vh;
}

.page-bd {
    flex: 1;
    height: 0;
    overflow-y: auto;
}

.page-ft {
    background: #fff;
    box-shadow: inset 0rpx 1rpx 2rpx 0rpx rgba(0,0,0,.1);
    flex-shrink: 0;
    padding: 16rpx 30rpx env(safe-area-inset-bottom);
}

.page .footerLeft,.page-ft {
    display: -webkit-flex;
    display: flex;
}

.page .footerLeft {
    flex: 1;
}

.page .footerLeft-item {
    color: #333;
    font-family: PingFangSC,PingFang SC;
    font-size: 24rpx;
    font-weight: 500;
    line-height: 34rpx;
    text-align: center;
}

.page .footerLeft-item__icon {
    height: 36rpx;
    width: 36rpx;
}

.page .footerRight {
    align-items: center;
    background: #824c96;
    border: 2rpx solid #824c96;
    border-radius: 9rpx;
    color: #fff;
    display: -webkit-flex;
    display: flex;
    flex-shrink: 0;
    font-size: 32rpx;
    font-weight: 500;
    height: 72rpx;
    justify-content: center;
    margin-top: 4rpx;
    width: 200rpx;
}

.page .footerRight.already {
    background: #f2f3f4;
    border: none;
    color: #cccfd5;
}

.page .section-block {
    background: #fff;
    border-radius: 16rpx;
    box-shadow: 0rpx 8rpx 24rpx 0rpx rgba(0,0,0,.1);
    margin: 0 30rpx 20rpx;
    padding: 20rpx;
}

.page .section-block:first-child {
    margin-top: 20rpx;
}

.page .section-block__title {
    color: #151719;
    font-family: PingFangSC,PingFang SC;
    font-size: 32rpx;
    font-weight: 600;
    line-height: 44rpx;
    margin-bottom: 18rpx;
    margin-top: 20rpx;
}

.page .section-block__bd {
    word-wrap: break-word;
    color: #52585f;
    font-family: PingFangSC,PingFang SC;
    font-size: 28rpx;
    font-weight: 400;
    line-height: 44rpx;
}

.page .icon-location {
    align-self: flex-start;
    flex-shrink: 0;
    height: 36rpx;
    margin-right: 12rpx;
    margin-top: 6rpx;
    width: 36rpx;
}

.page .share-item {
    align-items: center;
    background: #fff;
    border: 2rpx solid #824c96;
    border-radius: 9rpx;
    color: #824c96;
    display: -webkit-flex;
    display: flex;
    font-size: 32rpx;
    font-weight: 500;
    height: 72rpx;
    justify-content: center;
    margin-right: 30rpx;
    margin-top: 4rpx;
    width: 200rpx;
}

.page .position-name {
    word-wrap: break-word;
    color: #151719;
    font-family: PingFangSC,PingFang SC;
    font-size: 36rpx;
    font-weight: 600;
    line-height: 52rpx;
    margin-bottom: 12rpx;
}

.page .position-salary {
    font-size: 28rpx;
    margin-bottom: 12rpx;
}

.page .position-salary,.page .position-salaryLabel {
    color: #824c96;
    font-family: PingFangSC,PingFang SC;
    font-weight: 500;
    line-height: 40rpx;
}

.page .position-salaryLabel {
    font-size: 20rpx;
}

.page .position-address {
    color: #52585f;
    flex: 1;
    font-family: PingFangSC,PingFang SC;
    font-size: 24rpx;
    font-weight: 400;
    line-height: 44rpx;
    word-break: break-all;
}

.page .position-address-name {
    font-size: 28rpx;
    font-weight: 700;
}

.page .position-address text {
    display: inline-block;
}

.page .row-flex {
    display: -webkit-flex;
    display: flex;
}

.page .nav-btn-area {
    margin-left: 18rpx;
    text-align: end;
}

.page .nav-btn-area .icon-location-nav {
    height: 22rpx;
    margin-right: 8rpx;
    width: 16rpx;
}

.page .nav-btn-area .distance {
    color: #151719;
    font-size: 28rpx;
}

.page .nav-btn-area .nav-btn {
    color: #824c96;
    font-size: 24rpx;
}

.postionItem-welfare,.postionItem-welfare-label {
    align-items: center;
    display: -webkit-flex;
    display: flex;
}

.postionItem-welfare-label {
    background: #f7f8fa;
    border-radius: 4rpx;
    color: #52585f;
    font-size: 28rpx;
    margin-bottom: 8rpx;
    margin-right: 8rpx;
    padding: 2rpx 12rpx;
}

.icon-tel {
    height: 28rpx;
    margin-bottom: 2px;
    width: 28rpx;
}

.connect-info {
    color: #52585f;
    flex: 1;
    font-size: 24rpx;
    line-height: 36rpx;
    margin-right: 50rpx;
}

.connect-info__name {
    font-size: 28rpx;
    font-weight: 700;
    line-height: 44rpx;
    margin-bottom: 8rpx;
}

.connect-tel {
    color: #824c96;
    font-size: 24rpx;
    margin-top: 8rpx;
    text-align: center;
}

.footerLeft-item.mr {
    margin-right: 36rpx;
}

